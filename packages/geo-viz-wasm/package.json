  "license": "MIT OR Apache-2.0",
  "type": "module",
  "private": false,
  "files": [
    "index.d.ts",
    "index.js",
    "pkg/geo_viz_wasm.d.ts",
    "pkg/geo_viz_wasm.js",
    "pkg/geo_viz_wasm_bg.wasm",
