  "scripts": {
    "build": "bash scripts/build-wasm.sh",
    "test": "bash -lc 'bun test --parallel=\"${BUN_TEST_WORKERS:-${TEST_MAX_WORKERS:-2}}\" --max-concurrency=\"${BUN_TEST_MAX_CONCURRENCY:-${TEST_MAX_CONCURRENCY:-2}}\" tests'"
