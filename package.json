{
  "name": "@moenarch/geo-analysis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun --filter '@moenarch/*-wasm' test",
    "build": "bun --filter '@moenarch/*-wasm' build && bun --filter '@moenarch/*-app' build",
    "typecheck": "bun --filter '@moenarch/*-app' typecheck"
  }
}
